# ArcReel default deployment configuration (SQLite)
# Copy to .env and fill in your values

# ============================================================
# Authentication
# ============================================================
# Login username (default: admin)
AUTH_USERNAME=admin
# Login password (leave blank to auto-generate on first launch and write back to .env)
AUTH_PASSWORD=
# JWT signing secret (leave blank to auto-generate; note: tokens will be invalidated on restart, requiring re-login)
AUTH_TOKEN_SECRET=

# ============================================================
# Logging
# ============================================================
# Log level (default: INFO; options: DEBUG, WARNING, ERROR)
# LOG_LEVEL=INFO
