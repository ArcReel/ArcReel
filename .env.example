# ArcReel Generator Environment Configuration
# Copy this file to .env and fill in your values
#
# Most configuration (API keys, backend selection, rate limits, model selection, etc.)
# has been moved to the WebUI settings page (/settings) and can be configured there after first startup.
# This file only retains startup-level / infrastructure configuration.

# ============================================================
# Authentication Configuration
# ============================================================
# Login username (default: admin)
AUTH_USERNAME=admin
# Login password (leave empty to auto-generate on first startup and write back to this file)
AUTH_PASSWORD=
# JWT signing secret (leave empty to auto-generate, but tokens will be invalidated after restart)
AUTH_TOKEN_SECRET=

# ============================================================
# Database Configuration
# ============================================================
# Defaults to SQLite (development / single-machine)
# SQLite:     sqlite+aiosqlite:///./projects/.arcreel.db
# PostgreSQL: postgresql+asyncpg://user:pass@host:5432/arcreel
# DATABASE_URL=sqlite+aiosqlite:///./projects/.arcreel.db

# ============================================================
# Logging Configuration
# ============================================================
# Log level (default: INFO, options: DEBUG, WARNING, ERROR)
# LOG_LEVEL=INFO

# ============================================================
# Video Provider
# ============================================================
# DEFAULT_VIDEO_PROVIDER=gemini     # Global default video provider (gemini | seedance)

# ============================================================
# Seedance (Volcano Ark) Configuration
# ============================================================
# ARK_API_KEY=                      # Volcano Ark API key
# FILE_SERVICE_BASE_URL=            # Public URL for project file service (required for Seedance image uploads)
